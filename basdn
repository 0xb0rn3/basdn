usage() { usage_flow; }

LINK_FILE=""; DIRECT_URLS=(); OUTPUT_DIR="./basdn_downloads"
RESET_FLAG=""; SETUP_ONLY=false; NO_TUI=false; JOBS=3; SEGMENTS=8

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--file)      LINK_FILE="$2"; shift 2;;
    -u|--urls)      shift; while [[ $# -gt 0 && "$1" != -* ]]; do DIRECT_URLS+=("$1"); shift; done;;
    -o|--output)    OUTPUT_DIR="$2"; shift 2;;
    -j|--jobs)      JOBS="$2"; shift 2;;
    -s|--segments)  SEGMENTS="$2"; shift 2;;
    --reset)        RESET_FLAG="--reset"; shift;;
    --setup-only)   SETUP_ONLY=true; shift;;
    --no-tui)       NO_TUI=true; shift;;
    -h|--help)      banner; usage; exit 0;;
    *)              err "Unknown: $1"; usage; exit 1;;
  esac
done

banner
[[ -z "$LINK_FILE" && ${#DIRECT_URLS[@]} -eq 0 && "$SETUP_ONLY" == "false" ]] && usage_flow

step "Detecting Python"; divider
if ! PYTHON_BIN=$(find_python); then err "Python 3.8+ not found."; exit 1; fi
ok "Using: ${C_YELLOW}${PYTHON_BIN}${C_RESET} (${C_DIM}$("$PYTHON_BIN" --version 2>&1)${C_RESET})"

ensure_pip "$PYTHON_BIN"
install_deps "$PYTHON_BIN"

step "Preparing engine"; divider
if [[ ! -f "$PYTHON_SCRIPT" ]]; then
  err "Engine not found: $PYTHON_SCRIPT"
  err "Ensure basdn_engine.py is in the same directory as this script."
  exit 1
fi
ok "Engine ready: ${PYTHON_SCRIPT}"

[[ "$SETUP_ONLY" == "true" ]] && { ok "Setup complete."; exit 0; }

TMP_LINKS=""
if [[ -n "$LINK_FILE" ]]; then
  [[ ! -f "$LINK_FILE" ]] && { err "Not found: $LINK_FILE"; exit 1; }
  ok "File: ${C_YELLOW}${LINK_FILE}${C_RESET} ($(grep -cE '^https?://' "$LINK_FILE" 2>/dev/null || echo 0) URLs)"
elif [[ ${#DIRECT_URLS[@]} -gt 0 ]]; then
  TMP_LINKS=$(mktemp /tmp/basdn_XXXXXX.txt); printf '%s\n' "${DIRECT_URLS[@]}" > "$TMP_LINKS"
  ok "${#DIRECT_URLS[@]} URL(s) from CLI."
else
  step "Multi-Link Paste Mode"; TMP_LINKS=$(multilink_collector)
fi

PY_CMD=("$PYTHON_BIN" "$PYTHON_SCRIPT" "-o" "$OUTPUT_DIR" "-j" "$JOBS" "-s" "$SEGMENTS")
[[ -n "$RESET_FLAG" ]] && PY_CMD+=("$RESET_FLAG")
[[ "$NO_TUI" == "true" ]] && PY_CMD+=("--no-tui")
[[ -n "$LINK_FILE" ]] && PY_CMD+=("-f" "$LINK_FILE")
[[ -n "$TMP_LINKS" ]] && PY_CMD+=("-f" "$TMP_LINKS")

step "Launching BASDN v3.0 Turbo"; divider
info "Config: ${C_YELLOW}${JOBS}${C_RESET} files × ${C_YELLOW}${SEGMENTS}${C_RESET} seg = ${C_BGREEN}$((JOBS * SEGMENTS))${C_RESET} connections"
echo ""
"${PY_CMD[@]}"
EC=$?
[[ -n "$TMP_LINKS" && -f "$TMP_LINKS" ]] && rm -f "$TMP_LINKS"
exit $EC
