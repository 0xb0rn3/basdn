# Keep 'usage' as alias for -h flag
usage() { usage_flow; }

# ── Default values ───────────────────────────────────────────────────
LINK_FILE=""
DIRECT_URLS=()
OUTPUT_DIR="./basdn_downloads"
RESET_FLAG=""
SETUP_ONLY=false

# ── Parse args ───────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--file)
      LINK_FILE="$2"; shift 2 ;;
    -u|--urls)
      shift
      while [[ $# -gt 0 && "$1" != -* ]]; do
        DIRECT_URLS+=("$1"); shift
      done
      ;;
    -o|--output)
      OUTPUT_DIR="$2"; shift 2 ;;
    --reset)
      RESET_FLAG="--reset"; shift ;;
    --setup-only)
      SETUP_ONLY=true; shift ;;
    -h|--help)
      banner; usage; exit 0 ;;
    *)
      err "Unknown argument: $1"; usage; exit 1 ;;
  esac
done

# ════════════════════════════════════════════════════════════════════
#  MAIN EXECUTION
# ════════════════════════════════════════════════════════════════════
banner
usage_flow

# ── 1. Python detection ──────────────────────────────────────────────
step "Detecting Python interpreter"
divider
if ! PYTHON_BIN=$(find_python); then
  err "Python 3.8+ not found."
  err "Install it: sudo apt install python3   (or dnf/pacman equivalent)"
  exit 1
fi
PYVER=$("$PYTHON_BIN" --version 2>&1)
ok "Using: ${C_YELLOW}${PYTHON_BIN}${C_RESET}  (${C_DIM}${PYVER}${C_RESET})"

# ── 2. Ensure pip ────────────────────────────────────────────────────
ensure_pip "$PYTHON_BIN"

# ── 3. Install / verify dependencies ────────────────────────────────
install_deps "$PYTHON_BIN"

# ── 4. Write Python engine ───────────────────────────────────────────
step "Preparing download engine"
divider
write_python_script

if [[ "$SETUP_ONLY" == "true" ]]; then
  ok "Setup complete. Run ./basdn to start downloading."
  exit 0
fi

# ── 5. Collect URLs ──────────────────────────────────────────────────
TMP_LINKS=""

if [[ -n "$LINK_FILE" ]]; then
  # File mode — pass straight to Python
  if [[ ! -f "$LINK_FILE" ]]; then
    err "Link file not found: $LINK_FILE"
    exit 1
  fi
  LINK_COUNT=$(grep -cE '^https?://' "$LINK_FILE" 2>/dev/null || echo 0)
  ok "Link file: ${C_YELLOW}${LINK_FILE}${C_RESET} (${LINK_COUNT} URLs)"

elif [[ ${#DIRECT_URLS[@]} -gt 0 ]]; then
  # Direct URL mode
  TMP_LINKS=$(mktemp /tmp/basdn_links_XXXXXX.txt)
  printf '%s\n' "${DIRECT_URLS[@]}" > "$TMP_LINKS"
  ok "Using ${#DIRECT_URLS[@]} URL(s) from command line."

else
  # Interactive multi-paste mode
  step "Multi-Link Paste Mode"
  TMP_LINKS=$(multilink_collector)
fi

