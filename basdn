C_BCYAN=$'\033[1;36m'; C_BMAGENTA=$'\033[1;35m'

ts()     { date '+%H:%M:%S'; }
info()   { echo -e "${C_DIM}[$(ts)]${C_RESET} ${C_CYAN}${C_BOLD}ℹ${C_RESET}  $*"; }
ok()     { echo -e "${C_DIM}[$(ts)]${C_RESET} ${C_BGREEN}✔${C_RESET}  $*"; }
warn()   { echo -e "${C_DIM}[$(ts)]${C_RESET} ${C_BYELLOW}⚠${C_RESET}  $*"; }
err()    { echo -e "${C_DIM}[$(ts)]${C_RESET} ${C_BRED}✖${C_RESET}  $*" >&2; }
step()   { echo -e "\n${C_BCYAN}${C_BOLD}▶  $*${C_RESET}"; }
divider(){ echo -e "${C_DIM}──────────────────────────────────────────────────────────────${C_RESET}"; }

