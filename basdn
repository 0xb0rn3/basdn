PY_CMD=("$PYTHON_BIN" "$PYTHON_SCRIPT" "-o" "$OUTPUT_DIR")

if [[ -n "$RESET_FLAG" ]]; then
  PY_CMD+=("$RESET_FLAG")
fi

if [[ -n "$LINK_FILE" ]]; then
  PY_CMD+=("-f" "$LINK_FILE")
elif [[ -n "$TMP_LINKS" ]]; then
  PY_CMD+=("-f" "$TMP_LINKS")
fi

