SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="${SCRIPT_DIR}/basdn_engine.py"
VENV_DIR="${SCRIPT_DIR}/.basdn_venv"
DEPS_STAMP="${SCRIPT_DIR}/.basdn_deps_ok"

find_python() {
  for cmd in python3.14 python3.13 python3.12 python3.11 python3.10 python3.9 python3 python; do
    if command -v "$cmd" &>/dev/null; then
      local ver
      ver=$("$cmd" -c "import sys; print(sys.version_info >= (3,8))" 2>/dev/null || true)
      [[ "$ver" == "True" ]] && { echo "$cmd"; return 0; }
    fi
  done; return 1
}

get_pip_flags() {
  local python="$1" out
  out=$("$python" -m pip install --dry-run pip 2>&1 || true)
  echo "$out" | grep -qi "externally.managed\|break-system-packages" && echo "--break-system-packages" || echo ""
}

install_deps() {
  local python="$1"
  local packages=("requests" "colorama")
  step "Installing Python dependencies"; divider
  if [[ -f "$DEPS_STAMP" ]]; then
    local sp; sp=$(cat "$DEPS_STAMP" 2>/dev/null || true)
    if [[ "$sp" == "$python" ]]; then
      local aok=true
      for p in "${packages[@]}"; do "$python" -c "import $p" &>/dev/null || { aok=false; break; }; done
      [[ "$aok" == "true" ]] && { ok "Dependencies cached."; return 0; }
    fi
  fi
  local pf; pf=$(get_pip_flags "$python")
  [[ -n "$pf" ]] && info "PEP 668 — using ${C_YELLOW}${pf}${C_RESET}"
  local iok=false
  "$python" -m pip install --quiet --upgrade "${packages[@]}" $pf 2>/dev/null && iok=true
  [[ "$iok" == "false" ]] && "$python" -m pip install --quiet --user "${packages[@]}" 2>/dev/null && iok=true
  if [[ "$iok" == "false" ]]; then
    "$python" -m venv "$VENV_DIR" 2>/dev/null && "${VENV_DIR}/bin/pip" install --quiet "${packages[@]}" 2>/dev/null && { PYTHON_BIN="${VENV_DIR}/bin/python3"; iok=true; }
  fi
  if [[ "$iok" == "false" ]]; then
    command -v apt-get &>/dev/null && sudo apt-get install -y -qq python3-requests 2>/dev/null && iok=true
    command -v pacman &>/dev/null && sudo pacman -Sy --noconfirm python-requests 2>/dev/null && iok=true
  fi
  [[ "$iok" == "false" ]] && { err "Deps failed. Run: pip3 install requests colorama"; exit 1; }
  echo "$python" > "$DEPS_STAMP"; ok "Dependencies ready."
}

ensure_pip() {
  local python="$1"
  "$python" -m pip --version &>/dev/null && return 0
  warn "Bootstrapping pip..."
  command -v curl &>/dev/null && { curl -sS https://bootstrap.pypa.io/get-pip.py | "$python" - --quiet || true; }
  command -v wget &>/dev/null && { wget -qO- https://bootstrap.pypa.io/get-pip.py | "$python" - --quiet || true; }
  "$python" -m pip --version &>/dev/null || { err "pip failed"; exit 1; }
  ok "pip ready."
}

multilink_collector() {
  echo -e "
${C_BCYAN}${C_BOLD}╔══════════════════════════════════════════════════════════════╗
║              MULTI-LINK PASTE HANDLER                        ║
╚══════════════════════════════════════════════════════════════╝${C_RESET}
${C_WHITE}Paste URLs (space/newline separated), type one-by-one, or mix.
  ${C_GREEN}Enter${C_RESET}→add  ${C_YELLOW}DONE${C_RESET}→start  ${C_YELLOW}LIST${C_RESET}→show  ${C_YELLOW}CLEAR${C_RESET}→reset  ${C_RED}Ctrl+D${C_RESET}→done
${C_DIM}──────────────────────────────────────────────────────────────${C_RESET}" >&2
  local -a LINKS=(); local line token added
  while true; do
    echo -ne "${C_GREEN}${C_BOLD}[${#LINKS[@]} links] ${C_RESET}${C_WHITE}URL(s): ${C_RESET}" >&2
    if ! IFS= read -r line; then echo "" >&2; break; fi
    line="${line#"${line%%[![:space:]]*}"}"; line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue
    case "${line^^}" in
      DONE) break;;
      LIST)
        if [[ ${#LINKS[@]} -eq 0 ]]; then echo -e "  ${C_BYELLOW}⚠ Empty${C_RESET}" >&2; else
          echo -e "\n${C_BCYAN}Links (${#LINKS[@]}):${C_RESET}" >&2
          local i=1; for l in "${LINKS[@]}"; do echo -e "  ${C_DIM}${i}.${C_RESET} ${C_YELLOW}${l}${C_RESET}" >&2; ((i++)); done
          echo "" >&2
        fi; continue;;
      CLEAR) LINKS=(); echo -e "  ${C_BGREEN}✔ Cleared${C_RESET}" >&2; continue;;
    esac
    added=0; IFS=$' \t' read -r -a tokens <<< "$line"
    for token in "${tokens[@]}"; do
      token="${token#"${token%%[![:space:]]*}"}"; token="${token%"${token##*[![:space:]]}"}"
      [[ -z "$token" ]] && continue
      if echo "$token" | grep -qiE '^(https?|ftp)://'; then LINKS+=("$token"); ((added++))
      elif [[ ${#tokens[@]} -eq 1 ]]; then
        echo -e "  ${C_BYELLOW}⚠ Not a URL:${C_RESET} ${C_DIM}${token:0:80}${C_RESET}" >&2
        echo -ne "  ${C_YELLOW}Add anyway? [y/N]: ${C_RESET}" >&2
        local confirm; IFS= read -r confirm </dev/tty
        [[ "${confirm,,}" == "y" ]] && { LINKS+=("$token"); ((added++)); }
      fi
    done
    [[ $added -gt 0 ]] && echo -e "  ${C_BGREEN}✔ +${added}${C_RESET} ${C_DIM}(${#LINKS[@]} total)${C_RESET}" >&2
  done
  [[ ${#LINKS[@]} -eq 0 ]] && { echo -e "  ${C_BYELLOW}⚠ No links.${C_RESET}" >&2; exit 0; }
  echo -e "\n${C_BGREEN}✔ ${#LINKS[@]} queued — launching turbo...${C_RESET}\n" >&2
  local tf; tf=$(mktemp /tmp/basdn_XXXXXX.txt); printf '%s\n' "${LINKS[@]}" > "$tf"; echo "$tf"
}

